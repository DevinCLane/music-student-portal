<%- include('../../partials/header-teacher') -%>
<div class="container">
  <div class="sub-container">
    <div class="dashboard-heading">
      <p><strong>Name</strong>: <%= teacher.name %></p>
      <p><strong>Email</strong>: <%= teacher.email %></p>
      <a href="/teachers/logout" class="col-3 btn btn-primary">Logout</a>
    </div>
    <div class="dashboard-heading">
      <!-- add a new lesson plan -->
      <a class="btn btn-primary" href="/teachers/dashboard">Return to Dashboard</a>
      <a href="/teachers/students/<%= student._id%>/lessons/new" class="btn btn-primary">New Lesson</a>
      <!-- todo: delete student -->
      <!-- this should be a button only -->
    </div>
  </div>
    <div class="row justify-content-center mt-5">
      <!-- show the student's name -->
       <h1><%= student.name %></h1>
      <p><strong>Student email:</strong> <%= student.email %></p>
        <!-- lesson plans -->
      <ul class="lessons">
        <% for(var i=0; i<lessons.length; i++) {%>
          <li>
            <a href="/teachers/students/<%= student._id%>/lessons/<%= lessons[i]._id %>"><%= lessons[i].formattedDate %></a>
          </li>
        <% } %>
      </ul>
  </div>  
</div>
<%- include('../../partials/footer') -%>