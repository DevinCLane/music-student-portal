<%- include('../../partials/header-teacher') -%>
<div class="container">
    <div class="sub-container">
        <div class="dashboard-heading">
            <p><strong>Name</strong>: <%= teacher.name %></p>
            <p><strong>Email</strong>: <%= teacher.email %></p>
            <a href="/logout" class="col-3 btn btn-primary">Logout</a>
            <a class="btn btn-primary" href="/teachers/dashboard"
                >Return to Dashboard</a
            >
        </div>
    </div>
    <div class="sub-container">
        <h2>Add a student</h2>
        <form action="/teachers/students" method="POST" class="form-container">
            <div class="form-label-group">
                <label for="name" class="form-label">Name</label>
                <input
                    type="text"
                    class="form-control"
                    id="name"
                    name="name"
                    required
                />
            </div>
            <div class="form-label-group">
                <label for="email" class="form-label">Email</label>
                <input
                    type="email"
                    class="form-control"
                    id="email"
                    name="email"
                    required
                />
            </div>
            <button type="submit" class="btn btn-primary" value="Upload">
                Add student
            </button>
        </form>
    </div>
</div>
<%- include('../../partials/footer') -%>
